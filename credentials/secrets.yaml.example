# credentials/secrets.yaml — Sensitive values for cluster provisioning
# Copy this file to secrets.yaml and fill in actual values.
# This file is gitignored.

keycloak:
  admin_password: "<CHANGE_ME>"
  db_password: "<CHANGE_ME>"

argocd:
  repo_pat: ""  # GitHub Personal Access Token (only needed for private repos)

cloudflare:
  tunnel_token: ""  # CF Tunnel token (from CF dashboard: cloudflared service install <TOKEN>)
  credentials_file: "credentials/cloudflare-tunnel.json"  # Legacy: credentials JSON file
  cert_file: ""  # Optional: path to cloudflare cert.pem

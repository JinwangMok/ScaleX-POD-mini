# credentials/.baremetal-init.yaml — Bare-metal node connection info
# Copy this file to .baremetal-init.yaml and fill in actual values.
# Secrets (passwords, key paths) are referenced from .env via variable names.

# Network defaults for SDI host infrastructure (used by `scalex sdi init` without spec file).
# If omitted, falls back to hardcoded defaults (192.168.88.0/24).
networkDefaults:
  managementBridge: "br0"
  managementCidr: "192.168.88.0/24"
  gateway: "192.168.88.1"

targetNodes:
  # Case 1: Direct reachable node (same LAN as this machine)
  # - name: "playbox-0"
  #   direct_reachable: true
  #   node_ip: "192.168.88.8"
  #   adminUser: "jinwang"
  #   sshAuthMode: "key"  # "password" or "key"
  #   sshKeyPath: "SSH_KEY_PATH"  # variable name defined in .env

  # Case 2: Reachable via external IP (e.g. Tailscale)
  - name: "playbox-0"
    direct_reachable: false
    reachable_node_ip: "100.64.0.1"  # Tailscale IP
    node_ip: "192.168.88.8"  # LAN IP
    adminUser: "jinwang"
    sshAuthMode: "password"
    sshPassword: "PLAYBOX_0_PASSWORD"  # variable name defined in .env

  # Case 3a: Reachable via ProxyJump through another node (password auth)
  - name: "playbox-1"
    direct_reachable: false
    reachable_via: ["playbox-0"]
    node_ip: "192.168.88.9"
    adminUser: "jinwang"
    sshAuthMode: "password"
    sshPassword: "PLAYBOX_1_PASSWORD"  # variable name defined in .env

  # Case 3b: Reachable via ProxyJump with key auth (uncomment to use)
  # - name: "playbox-1"
  #   direct_reachable: false
  #   reachable_via: ["playbox-0"]
  #   node_ip: "192.168.88.9"
  #   adminUser: "jinwang"
  #   sshAuthMode: "key"
  #   sshKeyPath: "SSH_KEY_PATH"                        # key for target node
  #   sshKeyPathOfReachableNode: "PROXY_SSH_KEY_PATH"   # key for proxy hop (playbox-0)

  - name: "playbox-2"
    direct_reachable: false
    reachable_via: ["playbox-0"]
    node_ip: "192.168.88.10"
    adminUser: "jinwang"
    sshAuthMode: "password"
    sshPassword: "PLAYBOX_2_PASSWORD"

  - name: "playbox-3"
    direct_reachable: false
    reachable_via: ["playbox-0"]
    node_ip: "192.168.88.11"
    adminUser: "jinwang"
    sshAuthMode: "password"
    sshPassword: "PLAYBOX_3_PASSWORD"

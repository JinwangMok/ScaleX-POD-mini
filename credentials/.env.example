# credentials/.env — Secret values referenced by .baremetal-init.yaml
# Copy this file to .env and fill in actual values.
# This file is gitignored.

# SSH passwords (used when sshAuthMode = "password")
PLAYBOX_0_PASSWORD="changeme"
PLAYBOX_1_PASSWORD="changeme"
PLAYBOX_2_PASSWORD="changeme"
PLAYBOX_3_PASSWORD="changeme"

# SSH key paths (used when sshAuthMode = "key")
SSH_KEY_PATH="~/.ssh/id_ed25519"

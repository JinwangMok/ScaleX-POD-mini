#!/usr/bin/env bash
# playbox — Single CLI for k8s-playbox provisioning
set -euo pipefail

PLAYBOX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Ensure ~/bin is in PATH (tools installed there)
export PATH="${HOME}/bin:${PATH}"

# Source all library modules
source "${PLAYBOX_ROOT}/lib/common.sh"
source "${PLAYBOX_ROOT}/lib/preflight.sh"
source "${PLAYBOX_ROOT}/lib/network.sh"
source "${PLAYBOX_ROOT}/lib/cluster.sh"
source "${PLAYBOX_ROOT}/lib/gitops.sh"
source "${PLAYBOX_ROOT}/lib/oidc.sh"
source "${PLAYBOX_ROOT}/lib/tunnel.sh"
source "${PLAYBOX_ROOT}/lib/client.sh"

# --- CLI Usage ---
usage() {
    cat <<EOF
Usage: ./playbox <command> [flags]

Commands:
  up                    Full provisioning (all steps)
  preflight             Check tools, SSH, validate values.yaml
  prepare-nodes         Create ansible_user, netplan, kernel params
  create-tower          OpenTofu: create tower VM with k3s + ArgoCD
  create-sandbox        Kubespray: install K8s on bare-metal nodes
  bootstrap             Create secrets, apply ArgoCD spread.yaml
  configure-oidc        Keycloak realm/client/user via REST API
  generate-kubeconfig   Generate client kubeconfig with OIDC
  archive-repos         Archive old GitHub repos

  status                Show cluster status
  destroy-sandbox       Reset sandbox cluster
  destroy-tower         Destroy tower VM
  destroy-all           Full teardown
  discover-nics         SSH to nodes and print NIC info

Flags:
  --dry-run             Show what would be done (no changes)
  --from <step>         Resume from specific step (with 'up')
  --skip <step>         Skip a specific step (with 'up')
  --check               Ansible check mode (with prepare-nodes)
  --help, -h            Show this help

Examples:
  ./playbox up                          # Full provisioning
  ./playbox up --dry-run                # Preview all steps
  ./playbox up --from create-sandbox    # Resume from sandbox
  ./playbox up --skip create-tower      # Single-cluster mode
  ./playbox preflight                   # Check prerequisites
  ./playbox discover-nics               # Get NIC info for values.yaml
EOF
}

# --- Step definitions for 'up' command ---
readonly STEPS=(
    preflight
    prepare-nodes
    create-tower
    create-sandbox
    bootstrap
    configure-oidc
    generate-kubeconfig
)

# Map step names to functions
run_step() {
    local step="$1"
    case "${step}" in
        preflight)          preflight_run ;;
        prepare-nodes)      network_prepare_all ;;
        create-tower)       cluster_tower_create ;;
        create-sandbox)     cluster_sandbox_create ;;
        bootstrap)          gitops_bootstrap ;;
        configure-oidc)     oidc_configure ;;
        generate-kubeconfig) client_generate_kubeconfig ;;
        *)
            log_error "Unknown step: ${step}"
            return 1
            ;;
    esac
}

# --- Parse global flags ---
DRY_RUN="false"
FROM_STEP=""
SKIP_STEP=""
ANSIBLE_CHECK=""
COMMAND=""

parse_flags() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                DRY_RUN="true"
                export DRY_RUN
                shift
                ;;
            --from)
                FROM_STEP="$2"
                shift 2
                ;;
            --skip)
                SKIP_STEP="$2"
                shift 2
                ;;
            --check)
                ANSIBLE_CHECK="--check"
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            -*)
                log_error "Unknown flag: $1"
                usage
                exit 1
                ;;
            *)
                if [[ -z "${COMMAND}" ]]; then
                    COMMAND="$1"
                else
                    log_error "Unexpected argument: $1"
                    usage
                    exit 1
                fi
                shift
                ;;
        esac
    done
}

# --- Run 'up' command ---
cmd_up() {
    local started=false
    if [[ -z "${FROM_STEP}" ]]; then
        started=true
    fi

    for step in "${STEPS[@]}"; do
        if [[ "${started}" == "false" && "${step}" == "${FROM_STEP}" ]]; then
            started=true
        fi

        if [[ "${started}" == "false" ]]; then
            log_info "Skipping ${step} (before --from ${FROM_STEP})"
            continue
        fi

        if [[ -n "${SKIP_STEP}" && "${step}" == "${SKIP_STEP}" ]]; then
            log_info "Skipping ${step} (--skip)"
            continue
        fi

        log_step "Running step: ${step}"
        run_step "${step}"
    done

    echo ""
    log_info "=== Provisioning complete! ==="
}

# --- Status command ---
cmd_status() {
    log_step "Cluster Status"

    local tower_enabled
    tower_enabled=$(yq_read '.tower.enabled')

    if [[ "${tower_enabled}" == "true" ]]; then
        echo ""
        log_info "--- Tower Cluster ---"
        if [[ -f "${PLAYBOX_ROOT}/_generated/tower.kubeconfig" ]]; then
            KUBECONFIG="${PLAYBOX_ROOT}/_generated/tower.kubeconfig" ${KUBECTL} get nodes 2>/dev/null || log_warn "Tower unreachable"
        else
            log_warn "Tower kubeconfig not found"
        fi
    fi

    echo ""
    log_info "--- Sandbox Cluster ---"
    if [[ -f "${PLAYBOX_ROOT}/_generated/sandbox.kubeconfig" ]]; then
        KUBECONFIG="${PLAYBOX_ROOT}/_generated/sandbox.kubeconfig" ${KUBECTL} get nodes 2>/dev/null || log_warn "Sandbox unreachable"
        echo ""
        KUBECONFIG="${PLAYBOX_ROOT}/_generated/sandbox.kubeconfig" ${KUBECTL} get applicationsets -n argocd 2>/dev/null || true
    else
        log_warn "Sandbox kubeconfig not found"
    fi
}

# --- Discover NICs ---
cmd_discover_nics() {
    log_step "Discovering NICs on all nodes..."
    local superuser
    superuser=$(get_superuser)
    local nodes
    nodes=$(get_all_nodes)

    for node in ${nodes}; do
        local ip
        ip=$(get_node_ip "${node}")
        echo ""
        log_info "=== ${node} (${ip}) ==="
        ssh_cmd "${superuser}@${ip}" "ip -j link show | python3 -c \"
import json, sys
for d in json.load(sys.stdin):
    if d.get('link_type') == 'loopback': continue
    name = d.get('ifname', '?')
    mac = d.get('address', '?')
    state = d.get('operstate', '?').lower()
    print(f'  {name}: mac={mac} state={state}')
\"" 2>/dev/null || log_warn "Could not connect to ${node}"
    done
}

# --- Archive old repos ---
cmd_archive_repos() {
    log_step "Archiving old repositories..."

    if [[ "${DRY_RUN}" == "true" ]]; then
        log_info "[dry-run] Would archive: JinwangMok/b-bim-bap, JinwangMok/k8s-sandbox"
        return 0
    fi

    if ! command -v gh &>/dev/null; then
        log_error "GitHub CLI (gh) not found"
        return 1
    fi

    gh repo archive JinwangMok/k8s-sandbox --yes 2>/dev/null || log_warn "Could not archive k8s-sandbox"
    log_info "Old repos archived"
}

# --- Main dispatch ---
parse_flags "$@"

if [[ -z "${COMMAND}" ]]; then
    usage
    exit 1
fi

case "${COMMAND}" in
    up)                 cmd_up ;;
    preflight)          preflight_run ;;
    prepare-nodes)      network_prepare_all ;;
    create-tower)       cluster_tower_create ;;
    create-sandbox)     cluster_sandbox_create ;;
    bootstrap)          gitops_bootstrap ;;
    configure-oidc)     oidc_configure ;;
    generate-kubeconfig) client_generate_kubeconfig ;;
    archive-repos)      cmd_archive_repos ;;
    status)             cmd_status ;;
    destroy-sandbox)    cluster_sandbox_destroy ;;
    destroy-tower)      cluster_tower_destroy ;;
    destroy-all)
        cluster_sandbox_destroy
        cluster_tower_destroy
        ;;
    discover-nics)      cmd_discover_nics ;;
    *)
        log_error "Unknown command: ${COMMAND}"
        usage
        exit 1
        ;;
esac

# config/k8s-clusters.yaml — Multi-cluster Kubernetes configuration
# Defines how SDI pools are clustered via Kubespray and managed by ArgoCD.

config:
  common:
    kubernetes_version: "1.33.1"
    kubespray_version: "v2.30.0"
    container_runtime: "containerd"
    cni: "cilium"  # Managed by GitOps post-bootstrap; kubespray sets kube_network_plugin: cni
    cilium_version: "1.17.5"
    kube_proxy_remove: true
    cgroup_driver: "systemd"
    helm_enabled: true
    kube_apiserver_admission_plugins:
      - NodeRestriction
      - PodTolerationRestriction
    # Firewall / kube-vip (disabled for bare-metal + Cilium)
    firewalld_enabled: false
    kube_vip_enabled: false
    # Graceful node shutdown
    graceful_node_shutdown: true
    graceful_node_shutdown_sec: 120
    # Custom kubelet flags
    kubelet_custom_flags:
      - "--node-ip={{ ip }}"
    # Gateway API (for future Cilium Gateway)
    gateway_api_enabled: true
    gateway_api_version: "1.3.0"
    # Kubeconfig/kubectl on Ansible host (for bastion access)
    kubeconfig_localhost: true
    kubectl_localhost: true
    # Node-local DNS cache (performance)
    enable_nodelocaldns: true
    # Pod network node prefix (default: 24 = up to 254 pods/node)
    kube_network_node_prefix: 24
    # NTP synchronization
    ntp_enabled: true
    # Etcd deployment type: "host" (recommended for production), "docker", or "kubeadm"
    etcd_deployment_type: "kubeadm"
    # DNS mode: "coredns" (production standard)
    dns_mode: "coredns"

  clusters:
    # Mode: "sdi" (default) uses SDI VM pools, "baremetal" uses physical nodes directly
    - cluster_name: "tower"
      # cluster_mode: "sdi"  # default — omit for SDI mode
      cluster_sdi_resource_pool: "tower"  # Maps to sdi-specs.yaml spec.sdi_pools[].pool_name
      cluster_role: "management"  # Runs ArgoCD, manages other clusters
      ssh_user: "jinwang"  # SSH user for kubeconfig collection (default: "root")
      network:
        pod_cidr: "10.244.0.0/20"
        service_cidr: "10.96.0.0/20"
        dns_domain: "tower.local"
      cilium:
        cluster_id: 1
        cluster_name: "tower"
      kubespray_extra_vars:
        kube_api_anonymous_auth: true
        supplementary_addresses_in_ssl_keys:
          - "100.64.0.1"  # Tailscale bastion IP (for external kubectl via Tailscale)

    - cluster_name: "sandbox"
      cluster_sdi_resource_pool: "sandbox"
      cluster_role: "workload"
      network:
        pod_cidr: "10.233.0.0/17"
        service_cidr: "10.233.128.0/18"
        dns_domain: "sandbox.local"
        native_routing_cidr: "10.233.0.0/16"
      cilium:
        cluster_id: 2
        cluster_name: "sandbox"
      # OIDC authentication (Keycloak integration) — type-safe config
      oidc:
        enabled: true
        client_id: "kubernetes"
        issuer_url: "https://auth.jinwang.dev/realms/kubernetes"
        username_claim: "preferred_username"
        username_prefix: "oidc:"
        groups_claim: "groups"
        groups_prefix: "oidc:"
      kubespray_extra_vars:
        kube_api_anonymous_auth: true
        kubelet_config_extra_args:
          systemReserved:
            cpu: "200m"
            memory: "512Mi"
          kubeReserved:
            cpu: "200m"
            memory: "512Mi"
        supplementary_addresses_in_ssl_keys:
          - "100.64.0.1"  # Tailscale bastion IP

    # Example: baremetal mode (no SDI virtualization layer)
    # - cluster_name: "prod"
    #   cluster_mode: "baremetal"
    #   cluster_role: "workload"
    #   baremetal_nodes:
    #     - node_name: "node-0"
    #       ip: "10.0.0.1"
    #       roles: [control-plane, etcd]
    #     - node_name: "node-1"
    #       ip: "10.0.0.2"
    #       roles: [worker]
    #   network:
    #     pod_cidr: "10.234.0.0/17"
    #     service_cidr: "10.234.128.0/18"
    #     dns_domain: "prod.local"

  argocd:
    namespace: "argocd"
    repo_url: "https://github.com/JinwangMok/ScaleX-POD-mini.git"
    repo_branch: "main"
    tower_manages: ["sandbox"]  # Tower ArgoCD manages these clusters

  domains:
    auth: "auth.jinwang.dev"
    argocd: "cd.jinwang.dev"
    tower_api: "tower-api.jinwang.dev"
    sandbox_api: "sandbox-api.jinwang.dev"

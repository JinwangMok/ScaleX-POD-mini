        <mxCell id="ga-sandbox-cgen" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" edge="1" parent="1" source="g-sandbox-root" target="g-sandbox-common-gen"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ga-sandbox-sgen" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" edge="1" parent="1" source="g-sandbox-root" target="g-sandbox-gen"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ga-scgen-apps" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" edge="1" parent="1" source="g-sandbox-common-gen" target="g-sandbox-common-apps"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ga-sgen-apps" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;" edge="1" parent="1" source="g-sandbox-gen" target="g-sandbox-apps"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========================================= -->
        <!-- Sync Waves (Right Bottom)                 -->
        <!-- ========================================= -->
        <mxCell id="sw-title" value="Sync Waves" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1100" y="85" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="sw0" value="Wave 0&#xa;ArgoCD, cluster-config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="125" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sw1" value="Wave 1&#xa;Cilium, cert-manager, Kyverno,&#xa;local-path-provisioner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="185" width="220" height="55" as="geometry" />
        </mxCell>

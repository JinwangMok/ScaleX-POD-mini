        </mxCell>
        <mxCell id="g-tower-apps" value="gitops/tower/&#xa;argocd, cilium, cert-issuers,&#xa;keycloak, cloudflared,&#xa;socks5, cluster-config" style="shape=document;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="820" y="345" width="150" height="65" as="geometry" />

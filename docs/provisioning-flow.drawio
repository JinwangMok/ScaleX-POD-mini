        <mxCell id="swa01" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;strokeColor=#999999;" edge="1" parent="1" source="sw0" target="sw1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="swa12" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;strokeColor=#999999;" edge="1" parent="1" source="sw1" target="sw2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="swa23" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1;strokeColor=#999999;" edge="1" parent="1" source="sw2" target="sw3"><mxGeometry relative="1" as="geometry" /></mxCell>

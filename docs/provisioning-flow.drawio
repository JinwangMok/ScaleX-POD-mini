        <mxCell id="g-tower-common-apps" value="gitops/common/&#xa;cert-manager, cilium-res,&#xa;kyverno, kyverno-policies" style="shape=document;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">

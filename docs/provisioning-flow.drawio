<mxfile host="app.diagrams.net" modified="2026-03-13T00:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="provisioning-flow" name="Provisioning Flow">
    <mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="ScaleX-POD-mini Provisioning Flow" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="scalex CLI unified provisioning: facts → sdi init → cluster init → secrets apply → bootstrap" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="280" y="50" width="640" height="20" as="geometry" />
        </mxCell>

        <!-- ========================================= -->
        <!-- CLI Provisioning Flow (Left)              -->
        <!-- ========================================= -->
        <mxCell id="cli-title" value="scalex CLI Provisioning Steps" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="350" height="25" as="geometry" />
        </mxCell>

        <!-- Step 1: facts -->
        <mxCell id="s1" value="Step 1&#xa;scalex facts --all" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="125" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s1-detail" value="- SSH로 모든 베어메탈 노드 접속&#xa;- CPU, memory, GPU, disk, NIC, kernel 수집&#xa;- 결과: _generated/facts/{node}.json" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="120" width="280" height="55" as="geometry" />
        </mxCell>

        <!-- Step 2: sdi init -->
        <mxCell id="s2" value="Step 2&#xa;scalex sdi init&#xa;config/sdi-specs.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s2-detail" value="- OpenTofu HCL 생성 + tofu apply&#xa;- libvirt VM 풀 생성 (tower + sandbox)&#xa;- 결과: _generated/sdi/&#xa;- 소요: 노드당 ~5분" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="205" width="280" height="65" as="geometry" />
        </mxCell>

        <!-- Step 3: cluster init -->
        <mxCell id="s3" value="Step 3&#xa;scalex cluster init&#xa;config/k8s-clusters.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s3-detail" value="- Kubespray inventory.ini 생성 (ProxyJump)&#xa;- group_vars 생성 (OIDC, Cilium, etcd)&#xa;- Kubespray cluster.yml 실행&#xa;- kubeconfig 다운로드&#xa;- 결과: _generated/clusters/{name}/&#xa;- 소요: 클러스터당 ~15-30분" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="298" width="280" height="85" as="geometry" />
        </mxCell>

        <!-- Step 4: secrets apply -->
        <mxCell id="s4" value="Step 4&#xa;scalex secrets apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="415" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s4-detail" value="- Tower 클러스터에 시크릿 생성&#xa;- Keycloak admin/DB 비밀번호&#xa;- Cloudflare Tunnel credentials&#xa;- ArgoCD repo PAT (private repo)" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="408" width="280" height="65" as="geometry" />
        </mxCell>

        <!-- Step 5: bootstrap -->
        <mxCell id="s5" value="Step 5&#xa;scalex bootstrap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="505" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s5-detail" value="3-in-1 자동 실행:&#xa;  1. ArgoCD Helm 설치 (Tower)&#xa;  2. Sandbox 클러스터 등록 (argocd cluster add)&#xa;  3. spread.yaml 적용 → GitOps 체인 시작" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="498" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- Done -->
        <mxCell id="done" value="Platform Ready!&#xa;scalex status / scalex get clusters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="60" y="595" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- Step arrows -->
        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a23" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a34" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a45" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a5d" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" parent="1" source="s5" target="done"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========================================= -->
        <!-- GitOps Bootstrap Chain (Right Top)        -->
        <!-- ========================================= -->
        <mxCell id="gitops-title" value="GitOps Bootstrap Chain" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="700" y="85" width="350" height="25" as="geometry" />
        </mxCell>

        <mxCell id="g-spread" value="spread.yaml&#xa;(Root Bootstrap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="125" width="170" height="45" as="geometry" />

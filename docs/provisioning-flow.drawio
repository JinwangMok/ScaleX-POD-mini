        <!-- ========================================= -->
        <!-- Config Files + Tools (Bottom Right)       -->
        <!-- ========================================= -->
        <mxCell id="config-title" value="Config Files (User-Provided)" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1100" y="490" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="config-box" value="credentials/.baremetal-init.yaml — SSH 접근 정보&#xa;credentials/.env — SSH 비밀번호/키 경로&#xa;credentials/secrets.yaml — Keycloak, ArgoCD 시크릿&#xa;credentials/cloudflare-tunnel.json — CF Tunnel 인증&#xa;config/sdi-specs.yaml — VM 풀 정의 (CPU/RAM/disk)&#xa;config/k8s-clusters.yaml — 클러스터 정의 (CIDR, CNI)" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="520" width="340" height="100" as="geometry" />
        </mxCell>

        <mxCell id="tools-title" value="Tools Used" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1100" y="640" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="tools-box" value="OpenTofu + libvirt → SDI VM 풀&#xa;Kubespray (Ansible) → K8s 클러스터 (tower + sandbox)&#xa;Helm → ArgoCD 설치&#xa;argocd CLI → 클러스터 등록&#xa;kubectl apply → spread.yaml (GitOps 부트스트랩)&#xa;Cloudflare Tunnel → 외부 접근" style="text;html=1;align=left;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="670" width="320" height="100" as="geometry" />
        </mxCell>

      </root>

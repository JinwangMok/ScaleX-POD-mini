        <mxCell id="tailscale" value="Tailscale Bastion&#xa;(playbox-0 → external)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=2;" vertex="1" parent="lan-group">
